# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

EXPO_PUBLIC_REVENUECAT_IOS_KEY=YOUR_REVENUECAT_IOS_KEY

EXPO_PUBLIC_APP_ENV=development

# OPENAI_API_KEY, ELEVENLABS_API_KEY, and OZZIE_VOICE_ID are NOT set here.
# They are secrets used only by Supabase edge functions (supabase/functions/*)
# and must be set via `supabase secrets set` — never as EXPO_PUBLIC_* vars,
# which are embedded in the client bundle and extractable by anyone.
